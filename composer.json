{
    "name": "jzaaa/php-simple-captcha",
    "description": "Simple captcha generator",
    "type": "library",
    "license": "MIT",
    "keywords": ["captcha", "anti-spam", "spam-protection", "spam", "obfuscation", "security", "anti-bot", "no-bot", "bot-protection"],
    "homepage": "https://github.com/JZaaa/php-simple-captcha",
    "scripts": {
        "lint": "pint --verbose",
        "test": "phpunit"
    },
    "authors": [
    ],
    "require": {
        "php": ">=7.4 <8.6",
        "ext-gd": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.1",
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.5 || ^12.0",
        "mikey179/vfsstream": "^1.6",
        "vimeo/psalm": "^4.30 || ^5.26 || ^6.0"
    },
    "autoload": {
        "psr-4": {
            "SimpleCaptcha\\": "src/"
        }
    }
